# 链接层数据库（见 docs/public/PUB-02-architecture.md）
# 本地开发：默认指向引擎写入的 sqlite 文件，无需配置即可跑通。
#   LIBSQL_URL=file:../../data/agent_loop_tracking.db
#
# 生产 / 联调：指向同一个 Turso 库（引擎 TRACKING_SOURCE=cloud 写入的库）。
#   LIBSQL_URL=libsql://<your-db>.turso.io
#   LIBSQL_AUTH_TOKEN=<turso-token>

# LIBSQL_URL=file:../../data/agent_loop_tracking.db
# LIBSQL_AUTH_TOKEN=

# Console 最简登录（设 CONSOLE_AUTH_PASSWORD 即启用；未设则全站免登录）
# 生产：列表/运营页需登录；/suggestions/* 与 blockers/outcomes API 对管家深链免登录
# CONSOLE_AUTH_USER=admin
# CONSOLE_AUTH_PASSWORD=your-password
# CONSOLE_SESSION_SECRET=optional-random-string-for-cookie-value
