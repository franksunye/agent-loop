# 链接层数据库（见 docs/public/PUB-02-architecture.md）
# 本地开发：默认指向引擎写入的 sqlite 文件，无需配置即可跑通。
#   LIBSQL_URL=file:../../data/agent_loop_tracking.db
#
# 生产 / 联调：指向同一个 Turso 库（引擎 TRACKING_SOURCE=cloud 写入的库）。
#   LIBSQL_URL=libsql://<your-db>.turso.io
#   LIBSQL_AUTH_TOKEN=<turso-token>

# LIBSQL_URL=file:../../data/agent_loop_tracking.db
# LIBSQL_AUTH_TOKEN=
