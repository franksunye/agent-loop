# Agent-Loop 环境配置模板
# 复制为 .env 后填入真实值；.env 不会被提交（见 .gitignore）

# ===== 运行模式 =====
# 开发环境 E2E 共识：默认不真发企微（DRY_RUN=true）。真发消息是独立能力，仅在做
# 「发送真实消息」验证时设 DRY_RUN=false（见 docs/07-dev-e2e-consensus.md）。
DRY_RUN=true

# ===== 增量数据源（FSM 工单库）=====
# mongo : XLink dev/prod（v0.2 默认）—— 真实 serviceAppointment
# mock  : 仅离线 CI / 无网环境；非常态路径
FSM_SOURCE=mongo

# dev 只读（本地开发；口径见 docs/xlink-data.md；凭据勿提交仓库）
FSM_MONGO_URL=mongodb://xlinkdemo:YOUR_PWD@112.126.77.6:27017/xlinkdemo?directConnection=true&authSource=admin
FSM_MONGO_DB=xlinkdemo

# v0.2.0 封版验收：生产只读（见 docs/10 §5；账号见 xlink mongodb-connection-info）
# FSM_MONGO_URL=mongodb://<readonly>@112.126.77.6:27017/xlink?directConnection=true&authSource=admin
# FSM_MONGO_DB=xlink
FSM_TIME_FIELD=updateTime
FSM_BATCH_LIMIT=3
# dev 库完工单 updateTime 可能较旧；24h 常为 0 条，E2E 建议 2160；0=不按时间过滤
FSM_LOOKBACK_HOURS=2160

# v0.2 Follow-up wedge（见 docs/08-follow-up-wedge-spec.md）
# 仅待签约 206（204 不纳入，见 docs/08）
FSM_EVENT_STATUSES=206
# 仅跟进最近 14 天内有更新的 206；超过 2 周不再跟
FSM_MAX_AGE_DAYS=14
# FSM_STALE_DAYS=0

# v0.2 试点管家（生产：仅姓名；dev 无对应姓名时用 ID，勿与姓名同时配）
# FSM_PILOT_HOUSEKEEPERS=刘沐泽,李小军,刘清瑞,李俊达
# FSM_PILOT_HOUSEKEEPER_IDS=   # 配了 HOUSEKEEPERS 时会被忽略
# WECOM_WEBHOOK_MAP=userId:https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=...

# ===== 追踪库（幂等水位线 + reasoning_traces）=====
TRACKING_SOURCE=local
TRACKING_LOCAL_PATH=agent_loop_tracking.db
TURSO_URL=libsql://your-db-name.turso.io
TURSO_TOKEN=your_turso_auth_token

# ===== 推理 / LLM（见 docs/06-llm-providers.md）=====
# heuristic : 不走 API，验证捞取/追踪/企微等非 LLM 链路（零成本）
# hunyuan    : 腾讯混元 Lite（默认，免费，对齐 stockwise）
# deepseek   : 付费高质量，用于抽样对比验证
LLM_PROVIDER=hunyuan

# 混元（与 stockwise 一致：OpenAI 兼容端点）
HUNYUAN_API_KEY=
# LLM_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1
# LLM_MODEL=hunyuan-lite

# oneshot（对照/降级）| steps（v0.2.0 封版必用：先查证再建议，见 docs/10）
AGENT_MODE=steps

# v0.4：拼入 SOP（当前留空，见 sops/）
# SOP_VERSION=

# DeepSeek / 其它 OpenAI 兼容（LLM_PROVIDER=deepseek 时使用）
# LLM_API_KEY=sk-xxxx
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# ===== 输出：企业微信群机器人 =====
WECOM_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_key
