# Agent-Loop POC 环境配置模板
# 复制为 .env 后填入真实值；.env 不会被提交（见 .gitignore）

# ===== 运行模式 =====
# DRY_RUN=true 时：不调用真实 LLM、不发企微、不连真实 FSM 库，
#                  全流程在本地用 mock 数据跑通并打印结果（零成本验证）。
DRY_RUN=true

# ===== 增量数据源（FSM 工单库）=====
# mock     : 内置样例工单，零依赖（默认，用于先把链路跑通）
# mongo    : XLink 真实工单库（MongoDB serviceAppointment）—— 主路径
# postgres : 备用，若某数据源为 PostgreSQL（spec 原始设定）
FSM_SOURCE=mock

# --- mongo 模式（XLink）---
# dev:  mongodb://112.126.77.6:27017/xlinkdemo?directConnection=true&authSource=admin  (db=xlinkdemo, user=xlinkdemo)
# prod: mongodb://112.126.77.6:27017/xlink?directConnection=true&authSource=admin       (db=xlink)
# 凭据放在 URL 里：mongodb://<user>:<pwd>@112.126.77.6:27017/...，切勿提交真实密码
FSM_MONGO_URL=mongodb://USER:PWD@112.126.77.6:27017/xlinkdemo?directConnection=true&authSource=admin
FSM_MONGO_DB=xlinkdemo
FSM_MONGO_COLLECTION=serviceAppointment
# 已完工口径（已验证：403=已完工；同时强制 state=1 排除作废）
FSM_FINISHED_STATUS=403
# 增量时间字段：updateTime(状态变更时间) / createTime
FSM_TIME_FIELD=updateTime
# 单轮最多处理多少条，避免首跑积压过多
FSM_BATCH_LIMIT=50

# --- postgres 模式（备用）---
FSM_DB_URL=postgresql://readonly_user:password@host:5432/fsm

# 只回捞最近 N 小时内完工的工单（0=不限时间，纯靠追踪库去重）
FSM_LOOKBACK_HOURS=24

# ===== 追踪库（幂等水位线）=====
# local : 本地 sqlite（默认，POC 零成本）
# cloud : 复用团队已有 Turso
TRACKING_SOURCE=local
TRACKING_LOCAL_PATH=agent_loop_tracking.db
TURSO_URL=libsql://your-db-name.turso.io
TURSO_TOKEN=your_turso_auth_token

# ===== LLM =====
# 兼容 OpenAI 协议（OpenAI / DeepSeek / 阿里云百炼 等）
LLM_API_KEY=sk-xxxx
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ===== 输出：企业微信群机器人 =====
WECOM_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_key
